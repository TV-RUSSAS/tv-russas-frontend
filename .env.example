# ==============================================================================
# .env.example - FRONTEND
# ==============================================================================
# REGRAS DE SEGURANÇA:
# 1. Este arquivo é seguro para versionamento. Não coloque credenciais reais aqui.
# 2. Variáveis com prefixo NEXT_PUBLIC_ serão expostas ao navegador do cliente.
# 3. NUNCA coloque tokens privados, senhas, chaves de banco ou segredos em 
#    variáveis NEXT_PUBLIC_.
# ==============================================================================

# API
# Em desenvolvimento: http://localhost:3001
# Em produção: OBRIGATORIAMENTE https://...
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001

# ANALYTICS E TAG MANAGER
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# CLOUDFLARE TURNSTILE
# Chave de teste pública: 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"

# FLAGS E CONFIGURAÇÕES
NEXT_PUBLIC_ENABLE_RELATED_NEWS=true
NEXT_PUBLIC_ECONOMY_MODE=false
